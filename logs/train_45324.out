  Model: TinyLlama/TinyLlama-1.1B-Chat-v1.0
  base_L1 = alpha1 + alpha2 * (log(freq)-10)/5  + ctx_head(LLaMA_hidden)
  Mψ: sys_err = (7 - intended_sac_len)*(omega1 - log launch_dur)/omega2
      sigma   = eta1 + eta2 * intended_sac_len
      E[L1_ecc] = base_L1 * eps^(sys_err + (w-1)/2) * exp(0.5 sigma^2 (ln eps)^2)
  Refix: P_refix = clamp(lambda_refix * E[|landing - target|], 0, 0.95)
  L2 = delta * base_L1 | FFD = E[L1_ecc] + M1 + M2
  Gaze = FFD + P_refix * (L2 + M1 + M2)
  Integration: p_fail = sigmoid(ifail_offset + ifail_coef * log_freq_norm)
  Regression cost = p_correct * (M1+M2+0.1*L1+L2+I)
                  + (1-p_correct) * (M1+M2+0.1*L1[n-1]+L2[n-1]+I+A)
  TRT = Gaze + I + p_fail * regression_cost
  Skip = sigmoid((M1 - L1_next_parafoveal)/skip_temperature + residual)
